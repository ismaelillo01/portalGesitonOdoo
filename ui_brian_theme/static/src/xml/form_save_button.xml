<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ui_brian_theme.FormView" t-inherit="web.FormView" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='control-panel-status-indicator']" position="replace">
            <t t-set-slot="control-panel-status-indicator">
                <div t-if="canEdit or uiBrianViewTitle" class="o_ui_brian_form_actions d-flex align-items-center me-auto">
                    <t t-if="canEdit">
                        <button
                            type="button"
                            class="btn btn-primary"
                            data-hotkey="s"
                            t-att-disabled="!model.root.isNew and !model.root.isInEdition ? true : undefined"
                            t-on-click.stop="() => this.uiBrianManualSave()">
                            Guardar
                        </button>
                        <button
                            t-if="model.root.isNew or model.root.isInEdition"
                            type="button"
                            class="btn btn-secondary"
                            data-hotkey="j"
                            t-on-click.stop="discard">
                            Descartar
                        </button>
                    </t>
                    <span
                        t-if="!model.root.isNew and !model.root.isValid"
                        class="text-danger small">
                        <i class="fa fa-warning me-1"/>
                        Revisa los campos antes de guardar
                    </span>
                    <span
                        t-if="uiBrianViewTitle"
                        class="o_ui_brian_view_title o_ui_brian_view_title--form"
                        t-esc="uiBrianViewTitle"/>
                </div>
            </t>
        </xpath>
    </t>

    <t t-name="ui_brian_theme.FormViewButtons" t-inherit="web.FormView.Buttons" t-inherit-mode="extension">
        <xpath expr="//button[contains(@class, 'o_form_button_save')]" position="attributes">
            <attribute name="t-on-click.stop">() => this.uiBrianManualSave({ closable: true })</attribute>
        </xpath>
    </t>

</templates>
