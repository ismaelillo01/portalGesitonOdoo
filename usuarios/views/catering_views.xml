<odoo>
  <data>
    <record model="ir.ui.view" id="usuarios_catering_config_form">
      <field name="name">usuarios.catering.config.form</field>
      <field name="model">usuarios.catering.config</field>
      <field name="arch" type="xml">
        <form string="Configurar catering">
          <sheet>
            <group>
              <group string="Servicio">
                <field name="usuario_id" readonly="1" options="{'no_open': True}"/>
                <field name="service_code" readonly="1"/>
                <field name="proveedor_id" options="{'no_create': True, 'no_open': True}"/>
              </group>
              <group string="Vigencia">
                <field name="date_start"/>
                <field name="date_stop"/>
              </group>
            </group>

            <group string="Dias de la semana" col="2">
              <group>
                <field name="lunes"/>
                <field name="martes"/>
                <field name="miercoles"/>
                <field name="jueves"/>
              </group>
              <group>
                <field name="viernes"/>
                <field name="sabado"/>
                <field name="domingo"/>
              </group>
            </group>

            <group string="Dias suspendidos">
              <field name="suspension_ids" nolabel="1" context="{'default_config_id': id}">
                <list editable="bottom">
                  <field name="date_start"/>
                  <field name="date_stop"/>
                  <field name="name"/>
                </list>
                <form string="Suspension de catering">
                  <group>
                    <field name="date_start"/>
                    <field name="date_stop"/>
                    <field name="name"/>
                  </group>
                </form>
              </field>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.ui.view" id="usuarios_catering_proveedor_list">
      <field name="name">usuarios.catering.proveedor.list</field>
      <field name="model">usuarios.catering.proveedor</field>
      <field name="arch" type="xml">
        <list string="Proveedores de catering">
          <field name="name"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="usuarios_catering_proveedor_form">
      <field name="name">usuarios.catering.proveedor.form</field>
      <field name="model">usuarios.catering.proveedor</field>
      <field name="arch" type="xml">
        <form string="Proveedor de catering">
          <sheet>
            <group>
              <field name="name"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="action_catering_proveedores_window">
      <field name="name">Proveedores de catering</field>
      <field name="res_model">usuarios.catering.proveedor</field>
      <field name="view_mode">list,form</field>
      <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <menuitem
      name="Proveedores de catering"
      id="menu_catering_proveedores"
      parent="usuarios.menu_configuracion"
      action="action_catering_proveedores_window"
      sequence="40"
      groups="base.group_system"
    />
  </data>
</odoo>
