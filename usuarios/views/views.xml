<odoo>
  <data>
    <record model="ir.ui.view" id="usuarios.usuario_list">
      <field name="name">usuario.list</field>
      <field name="model">usuarios.usuario</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="apellido1"/>
          <field name="apellido2"/>
          <field name="dni_nie"/>
          <field name="telefono"/>
          <field name="servicio_ids" widget="many2many_tags"/>
          <field name="grupo"/>
          <field name="zona_trabajo_id"/>
          <field name="baja"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="usuarios.usuario_form">
      <field name="name">usuario.form</field>
      <field name="model">usuarios.usuario</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group string="Datos Personales">
                <field name="name"/>
                <field name="apellido1"/>
                <field name="apellido2"/>
                <field name="dni_nie"/>
              </group>
              <group string="Datos de Contacto">
                <field name="telefono"/>
                <field name="direccion"/>
              </group>
            </group>
            <group string="Datos Asignacion">
              <group>
                <field name="grupo"/>
                <field name="zona_trabajo_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="servicio_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
              </group>
              <group>
                <field name="baja"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="usuarios.action_window">
      <field name="name">Usuarios</field>
      <field name="res_model">usuarios.usuario</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Usuarios" id="usuarios.menu_root"/>
    <menuitem name="Usuarios" id="usuarios.menu_usuarios" parent="usuarios.menu_root" sequence="10"/>
    <menuitem
      name="Todos los Usuarios"
      id="usuarios.menu_1_list"
      parent="usuarios.menu_usuarios"
      action="usuarios.action_window"
    />
  </data>
</odoo>
