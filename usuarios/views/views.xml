<odoo>
  <data>
    <record model="ir.ui.view" id="usuarios.usuario_list">
      <field name="name">usuario.list</field>
      <field name="model">usuarios.usuario</field>
      <field name="arch" type="xml">
        <list>
          <header>
            <button
              name="%(usuarios.action_my_users_window)d"
              type="action"
              string="Ver mis usuarios"
              display="always"
            />
          </header>
          <field name="manager_edit_blocked" column_invisible="True"/>
          <field name="name"/>
          <field name="apellido1"/>
          <field name="apellido2"/>
          <field name="dni_nie"/>
          <field name="telefono"/>
          <field name="localidad_id"/>
          <field name="gestor_id" optional="show" options="{'no_open': True}"/>
          <field name="servicio_ids" widget="many2many_tags"/>
          <field name="grupo"/>
          <field name="zona_trabajo_id"/>
          <field name="baja"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="usuarios.usuario_form">
      <field name="name">usuario.form</field>
      <field name="model">usuarios.usuario</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <field name="manager_edit_blocked" invisible="1"/>
            <field name="group_selection_locked" invisible="1"/>
            <group>
              <group string="Datos Personales">
                <field name="name" readonly="manager_edit_blocked"/>
                <field name="apellido1" readonly="manager_edit_blocked"/>
                <field name="apellido2" readonly="manager_edit_blocked"/>
                <field name="dni_nie" readonly="manager_edit_blocked"/>
              </group>
              <group string="Datos de Contacto">
                <field name="telefono" readonly="manager_edit_blocked"/>
                <field name="direccion" readonly="manager_edit_blocked"/>
                <field name="localidad_id" readonly="manager_edit_blocked" groups="base.group_system"/>
                <field name="localidad_id" readonly="manager_edit_blocked" options="{'no_create': True, 'no_open': True}" groups="base.group_user,!base.group_system"/>
              </group>
            </group>
            <group string="Datos Asignacion">
              <group>
                <field name="grupo" readonly="manager_edit_blocked or group_selection_locked"/>
                <field name="zona_trabajo_id" readonly="manager_edit_blocked" options="{'no_create': True, 'no_open': True}"/>
                <field name="gestor_id" readonly="manager_edit_blocked" domain="[('grupo', '!=', 'administrador')]" options="{'no_create': True, 'no_open': True}"/>
                <field name="servicio_ids" readonly="manager_edit_blocked" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
              </group>
              <group>
                <field name="baja" readonly="manager_edit_blocked"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.ui.view" id="usuarios.servicio_list">
      <field name="name">usuarios.servicio.list</field>
      <field name="model">usuarios.servicio</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence"/>
          <field name="name"/>
          <field name="code"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="usuarios.servicio_form">
      <field name="name">usuarios.servicio.form</field>
      <field name="model">usuarios.servicio</field>
      <field name="arch" type="xml">
        <form string="Servicio">
          <sheet>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="sequence"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="usuarios.action_window">
      <field name="name">Usuarios</field>
      <field name="res_model">usuarios.usuario</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.act_window" id="usuarios.action_my_users_window">
      <field name="name">Ver mis usuarios</field>
      <field name="res_model">usuarios.usuario</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[('gestor_id.user_id', '=', uid)]</field>
    </record>

    <record model="ir.actions.act_window" id="usuarios.action_servicios_window">
      <field name="name">Servicios</field>
      <field name="res_model">usuarios.servicio</field>
      <field name="view_mode">list,form</field>
      <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <menuitem name="Usuarios" id="usuarios.menu_root"/>
    <menuitem name="Usuarios" id="usuarios.menu_usuarios" parent="usuarios.menu_root" sequence="10"/>
    <menuitem name="Configuración" id="usuarios.menu_configuracion" parent="usuarios.menu_root" sequence="30" groups="base.group_system"/>
    <menuitem
      name="Todos los Usuarios"
      id="usuarios.menu_1_list"
      parent="usuarios.menu_usuarios"
      action="usuarios.action_window"
    />
    <menuitem
      name="Servicios"
      id="usuarios.menu_servicios"
      parent="usuarios.menu_configuracion"
      action="usuarios.action_servicios_window"
      sequence="10"
      groups="base.group_system"
    />
    <menuitem
      name="Zonas de Trabajo"
      id="usuarios.menu_zonas_trabajo"
      parent="usuarios.menu_configuracion"
      action="zonasTrabajo.action_window"
      sequence="20"
      groups="base.group_system"
    />
    <menuitem
      name="Localidades"
      id="usuarios.menu_localidades"
      parent="usuarios.menu_configuracion"
      action="zonasTrabajo.action_localidad_window"
      sequence="30"
      groups="base.group_system"
    />
  </data>
</odoo>
