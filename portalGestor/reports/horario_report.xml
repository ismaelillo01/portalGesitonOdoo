<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_horario_trabajador" model="ir.actions.report">
        <field name="name">Horario de AP</field>
        <field name="model">portalgestor.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">portalGestor.report_horario_trabajador_template</field>
        <field name="report_file">portalGestor.report_horario_trabajador_template</field>
        <field name="print_report_name">(object.trabajador_ids[0].name + ' (' + object._get_nombre_mes_anio() + ')') if len(object.trabajador_ids) > 0 else 'Horarios'</field>
        <field name="binding_model_id" ref="model_portalgestor_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_horario_trabajador_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-foreach="doc.trabajador_ids" t-as="trabajador">
                        <t t-set="payload" t-value="doc._get_report_payload_for_worker(trabajador)"/>
                        <div class="page" t-att-style="'page-break-after: always;' if not trabajador_last else ''">
                            <div class="text-center mb-4">
                                <h2>Horario Mensual</h2>
                                <h4>AP: <t t-esc="trabajador.name"/></h4>
                                <p>Periodo: <span t-esc="doc._get_nombre_mes_anio()"/></p>
                            </div>

                            <div class="alert alert-info mt-4" role="alert" t-if="not payload['lines']">
                                <p class="mb-0">Sin registros en este periodo.</p>
                            </div>

                            <table class="table table-sm table-bordered mt-4" t-if="payload['lines']">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Usuario</th>
                                        <th>Hora Inicio</th>
                                        <th>Hora Fin</th>
                                        <th>Horas tramo</th>
                                        <th>Incidencia</th>
                                        <th>Motivo</th>
                                        <th>Horas no trabajadas</th>
                                        <th>Horas computables</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="payload['lines']" t-as="line">
                                        <tr>
                                            <td><span t-esc="line['fecha_label']"/></td>
                                            <td><span t-esc="line['usuario_name']"/></td>
                                            <td><span t-esc="line['hora_inicio']"/></td>
                                            <td><span t-esc="line['hora_fin']"/></td>
                                            <td><span t-esc="line['horas_tramo_label']"/></td>
                                            <td><span t-esc="line['incidencia_label'] or '-'"/></td>
                                            <td><span t-esc="line['motivo'] or '-'"/></td>
                                            <td><span t-esc="line['horas_no_trabajadas_label']"/></td>
                                            <td><span t-esc="line['horas_computables_label']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <div class="mt-4 text-end" t-if="payload['lines']">
                                <h4><strong>Total Horas del Periodo: <span t-esc="payload['total_duration_label']"/></strong></h4>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
