<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_hogar_riesgo" model="ir.actions.report">
        <field name="name">Hogares de Riesgo</field>
        <field name="model">portalgestor.hogar.riesgo.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">portalGestor.report_hogar_riesgo_template</field>
        <field name="report_file">portalGestor.report_hogar_riesgo_template</field>
        <field name="print_report_name">object._get_single_report_filename()</field>
        <field name="binding_model_id" ref="model_portalgestor_hogar_riesgo_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_hogar_riesgo_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-foreach="doc._get_report_hogar_riesgo_options()" t-as="hogar_option">
                    <t t-set="hogar_riesgo" t-value="hogar_option[0]"/>
                    <t t-set="payload" t-value="doc._get_report_payload_for_hogar_riesgo(hogar_riesgo)"/>
                    <t t-call="web.external_layout">
                        <div class="page" t-att-style="'page-break-after: always;' if not hogar_option_last else ''">
                            <div class="text-center mb-4">
                                <h2>Reporte de Hogar de Riesgo</h2>
                                <h4>Hogar: <t t-esc="payload['hogar_label']"/></h4>
                                <p>Grupo: <span t-esc="payload['group_label'] or '-'"/></p>
                                <p>Periodo: <span t-esc="payload['period_label']"/></p>
                            </div>

                            <table class="table table-sm table-bordered mt-4">
                                <tbody>
                                    <tr>
                                        <th style="width: 50%;">Usuarios en el hogar</th>
                                        <td><span t-esc="payload['user_count']"/></td>
                                    </tr>
                                    <tr>
                                        <th>Total horas atendidas</th>
                                        <td><span t-esc="payload['total_hours_label']"/></td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="alert alert-info mt-4" role="alert" t-if="not payload['user_rows']">
                                <p class="mb-0">No hay usuarios activos con servicio AP en este hogar de riesgo.</p>
                            </div>

                            <table class="table table-sm table-bordered mt-4" t-if="payload['user_rows']">
                                <thead>
                                    <tr>
                                        <th>Usuario</th>
                                        <th>Localidad</th>
                                        <th>Horas atendidas</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="payload['user_rows']" t-as="line">
                                        <tr>
                                            <td><span t-esc="line['full_name']"/></td>
                                            <td><span t-esc="line['localidad_name'] or '-'"/></td>
                                            <td><span t-esc="line['hours_label']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
