<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portalgestor_report_wizard_form" model="ir.ui.view">
        <field name="name">portalgestor.report.wizard.form</field>
        <field name="model">portalgestor.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar Horario AP PDF">
                <sheet>
                    <group>
                        <field name="exportar_todos" widget="boolean_toggle"/>
                        <field name="trabajador_ids" widget="many2many_tags" options="{'no_create': True}" invisible="exportar_todos == True" required="exportar_todos == False"/>
                        <field name="mes"/>
                        <field name="anio"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Imprimir PDF" type="object" name="action_print_report" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_portalgestor_report_wizard" model="ir.actions.act_window">
        <field name="name">Exportar Horario AP PDF</field>
        <field name="res_model">portalgestor.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menú para lanzar el wizard -->
    <menuitem name="Reportes" id="portalgestor_menu_reportes" parent="portalgestor_menu_root"/>
    <menuitem name="Exportar Horario" id="portalgestor_menu_exportar_horario" parent="portalgestor_menu_reportes" action="action_portalgestor_report_wizard"/>
</odoo>
