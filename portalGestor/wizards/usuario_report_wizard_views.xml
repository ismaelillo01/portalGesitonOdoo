<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portalgestor_usuario_report_wizard_form" model="ir.ui.view">
        <field name="name">portalgestor.usuario.report.wizard.form</field>
        <field name="model">portalgestor.usuario.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Horarios de usuarios">
                <sheet>
                    <group>
                        <field name="exportar_todos_activos" widget="boolean_toggle"/>
                        <field name="usuario_ids" widget="many2many_tags" options="{'no_create': True}" invisible="exportar_todos_activos == True" required="exportar_todos_activos == False"/>
                        <field name="mes"/>
                        <field name="anio"/>
                        <field name="formato_salida"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Generar reporte" type="object" name="action_generate_report" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_portalgestor_usuario_report_wizard" model="ir.actions.act_window">
        <field name="name">Horarios de usuarios</field>
        <field name="res_model">portalgestor.usuario.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_portalgestor_usuario_report_wizard_form"/>
        <field name="target">new</field>
    </record>

    <menuitem
        name="Reportes"
        id="usuarios_menu_reportes"
        parent="usuarios.menu_root"
        sequence="20"
    />

    <menuitem
        name="Exportar Horario Usuarios"
        id="portalgestor_menu_exportar_horario_usuarios"
        parent="usuarios_menu_reportes"
        action="action_portalgestor_usuario_report_wizard"
    />
</odoo>
