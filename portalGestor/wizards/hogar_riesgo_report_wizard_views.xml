<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portalgestor_hogar_riesgo_report_wizard_form" model="ir.ui.view">
        <field name="name">portalgestor.hogar.riesgo.report.wizard.form</field>
        <field name="model">portalgestor.hogar.riesgo.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar Hogares de Riesgo">
                <sheet>
                    <group>
                        <field name="mes"/>
                        <field name="anio"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Generar reporte" type="object" name="action_generate_report" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_portalgestor_hogar_riesgo_report_wizard" model="ir.actions.act_window">
        <field name="name">Exportar Hogares de Riesgo</field>
        <field name="res_model">portalgestor.hogar.riesgo.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_portalgestor_hogar_riesgo_report_wizard_form"/>
        <field name="target">new</field>
    </record>

    <menuitem
        name="Exportar Hogares de Riesgo"
        id="portalgestor_menu_exportar_hogar_riesgo"
        parent="usuarios_menu_reportes"
        action="action_portalgestor_hogar_riesgo_report_wizard"
        sequence="20"
    />
</odoo>
