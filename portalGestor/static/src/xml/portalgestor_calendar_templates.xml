<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="portalGestor.UserAutocompleteOption">
        <span class="o_portalgestor_user_option">
            <span class="o_portalgestor_user_option_name">
                <t t-esc="option.label"/>
            </span>
            <span
                t-if="option.portalGestorUserTypeBadge"
                class="o_portalgestor_user_option_badge"
                t-att-title="option.portalGestorUserTypeLabel"
            >
                <t t-esc="option.portalGestorUserTypeBadge"/>
            </span>
        </span>
    </t>

    <t t-name="portalGestor.CalendarBucketDialog">
        <Dialog
            title="props.title"
            size="'md'"
            contentClass="'o_portalgestor_bucket_dialog'"
            bodyClass="'o_portalgestor_bucket_dialog_body'"
            footer="false"
        >
            <div class="o_portalgestor_bucket_dialog_meta">
                <span
                    class="o_portalgestor_bucket_dialog_badge"
                    t-att-class="'o_portalgestor_bucket_dialog_badge--' + props.bucketType"
                >
                    <t t-esc="props.label"/> [<t t-esc="state.count"/>]
                </span>
            </div>
            <div class="o_portalgestor_bucket_dialog_list d-flex flex-column gap-2">
                <t t-if="state.records.length">
                    <t t-foreach="state.records" t-as="record" t-key="record.id">
                        <button
                            type="button"
                            class="btn text-start o_portalgestor_bucket_record"
                            t-att-class="'o_portalgestor_bucket_record--' + props.bucketType"
                            t-on-click="() => this.openRecord(record)"
                        >
                            <span class="o_portalgestor_user_option">
                                <span class="o_portalgestor_user_option_name">
                                    <t t-esc="record.name"/>
                                </span>
                                <span
                                    t-if="record.gestor_name"
                                    class="o_portalgestor_user_option_badge o_portalgestor_user_option_badge--owner"
                                    t-att-title="'Gestor: ' + record.gestor_name"
                                >
                                    <t t-esc="record.gestor_name"/>
                                </span>
                                <span
                                    t-if="record.user_type_badge"
                                    class="o_portalgestor_user_option_badge"
                                    t-att-title="record.user_type_label"
                                >
                                    <t t-esc="record.user_type_badge"/>
                                </span>
                            </span>
                        </button>
                    </t>
                </t>
                <t t-else="">
                    <div class="text-muted">No hay registros.</div>
                </t>
            </div>
        </Dialog>
    </t>

    <t t-name="portalGestor.UserHoursSummaryApDialog">
        <Dialog
            title="'Detalle de kilometraje'"
            size="'md'"
            contentClass="'o_portalgestor_user_hours_dialog'"
            bodyClass="'o_portalgestor_user_hours_dialog_body'"
            footer="false"
        >
            <div class="o_portalgestor_user_hours_dialog_header">
                <span class="o_portalgestor_user_hours_dialog_caption">AP</span>
                <div class="o_portalgestor_user_hours_dialog_worker">
                    <button
                        type="button"
                        class="o_portalgestor_user_hours_dialog_worker_name"
                        t-on-click="() => this.openWorker()"
                        title="Abrir ficha del AP"
                    >
                        <t t-esc="props.ap.name"/>
                    </button>
                    <span
                        class="o_portalgestor_user_hours_dialog_worker_phone"
                        t-esc="props.ap.phone || 'Sin telefono'"
                    />
                </div>
            </div>
            <div class="o_portalgestor_user_hours_dialog_grid">
                <div class="o_portalgestor_user_hours_dialog_metric">
                    <span>Dias atendidos</span>
                    <strong t-esc="props.ap.attended_day_count"/>
                </div>
                <div class="o_portalgestor_user_hours_dialog_metric">
                    <span>Kilometraje</span>
                    <strong t-esc="props.ap.kilometraje_km_label"/>
                </div>
                <div class="o_portalgestor_user_hours_dialog_metric">
                    <span>Valor kilometro</span>
                    <strong t-esc="props.ap.kilometraje_rate_label"/>
                </div>
                <div class="o_portalgestor_user_hours_dialog_metric">
                    <span>Desplazamiento</span>
                    <strong t-esc="props.ap.desplazamiento_label"/>
                </div>
            </div>
            <div class="o_portalgestor_user_hours_dialog_total">
                <span>
                    <t t-esc="props.ap.kilometraje_km_label"/>
                    x
                    <t t-esc="props.ap.attended_day_count"/>
                    dias
                    x
                    <t t-esc="props.ap.kilometraje_rate_label"/>
                </span>
                <strong t-esc="props.ap.kilometraje_total_label"/>
            </div>
            <p class="o_portalgestor_user_hours_dialog_note">
                El desplazamiento es informativo y no se suma a las horas computables del mes.
            </p>
        </Dialog>
    </t>

    <t t-name="portalGestor.UserHoursSummaryPanel">
        <t t-set="summary" t-value="portalGestorUserHoursSummary"/>
        <section class="o_portalgestor_user_hours_summary" t-if="summary">
            <div class="o_portalgestor_user_hours_summary_header">
                <span class="o_portalgestor_user_hours_summary_title">Horas del mes</span>
                <strong class="o_portalgestor_user_hours_summary_total" t-esc="summary.total_label"/>
            </div>
            <div class="o_portalgestor_user_hours_summary_body">
                <t t-if="summary.aps.length">
                    <t t-foreach="summary.aps" t-as="ap" t-key="ap.id">
                        <button
                            type="button"
                            class="o_portalgestor_user_hours_summary_ap"
                            t-on-click="() => this.openPortalGestorUserHoursSummaryAp(ap)"
                        >
                            <span class="o_portalgestor_user_hours_summary_ap_main">
                                <span class="o_portalgestor_user_hours_summary_ap_name" t-esc="ap.name"/>
                                <span class="o_portalgestor_user_hours_summary_ap_hours" t-esc="ap.label"/>
                            </span>
                            <span class="o_portalgestor_user_hours_summary_ap_meta">
                                <span t-esc="ap.kilometraje_total_label"/>
                                <span t-esc="ap.desplazamiento_label"/>
                            </span>
                            <span
                                t-if="ap.justified_minutes"
                                class="o_portalgestor_user_hours_summary_justified"
                            >
                                <span class="o_portalgestor_user_hours_summary_justified_total">
                                    Falta justificada no computada:
                                    <t t-esc="ap.justified_label"/>
                                </span>
                                <t t-foreach="ap.incidents" t-as="incident" t-key="incident.date + '-' + incident.range + '-' + incident.label">
                                    <span class="o_portalgestor_user_hours_summary_incident">
                                        <span t-esc="incident.date"/>
                                        <span t-esc="incident.range"/>
                                        <span t-esc="incident.label"/>
                                        <span t-if="incident.reason" t-esc="incident.reason"/>
                                    </span>
                                </t>
                            </span>
                        </button>
                    </t>
                </t>
                <t t-else="">
                    <div class="o_portalgestor_user_hours_summary_empty">
                        No hay horas computables con AP asignado.
                    </div>
                </t>
            </div>
            <div
                t-if="summary.unassigned_minutes"
                class="o_portalgestor_user_hours_summary_unassigned"
            >
                Sin AP asignado:
                <strong t-esc="summary.unassigned_label"/>
                no computadas.
            </div>
        </section>
    </t>

    <t t-inherit="web.CalendarController" t-inherit-mode="extension">
        <xpath expr="//button[contains(@class, 'o_calendar_button_today')]" position="after">
            <button
                t-if="showPortalGestorOnlyMineToggle"
                type="button"
                class="btn d-print-none o_portalgestor_only_mine_toggle"
                t-att-class="portalGestorOnlyMineState.onlyMine ? 'btn-primary' : 'btn-secondary'"
                t-on-click="togglePortalGestorOnlyMine"
            >
                <i class="fa fa-user-o me-1"/>
                <span>Ver mis horarios</span>
            </button>
        </xpath>
    </t>

    <t t-inherit="web.CalendarFilterPanel" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'o_calendar_filter')]" position="inside">
            <t t-if="showPortalGestorUserHoursSummary(section)">
                <t t-call="portalGestor.UserHoursSummaryPanel"/>
            </t>
        </xpath>
    </t>
</templates>
