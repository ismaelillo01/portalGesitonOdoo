<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="gestores.NavBarAppsVisibility" t-inherit="web.NavBar.AppsMenu" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='env.isSmall']" position="before">
            <t t-set="apps" t-value="getVisibleAppsForGestores(menuService.getApps())"/>
        </xpath>
    </t>

</templates>
