<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="gestores.gestores_list">
      <field name="name">gestor.list</field>
      <field name="model">gestores.gestor</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="grupo"/>
          <field name="user_id"/>
        </list>
      </field>
    </record>

    <!-- explicit form view definition -->
    <record model="ir.ui.view" id="gestores.gestores_form">
      <field name="name">gestor.form</field>
      <field name="model">gestores.gestor</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="grupo"/>
              <field name="user_id"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="gestores.action_window">
      <field name="name">Gestores</field>
      <field name="res_model">gestores.gestor</field>
      <field name="view_mode">list,form</field>
      <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Top menu item -->
    <menuitem name="Gestores" id="gestores.menu_root" groups="base.group_system"/>

    <!-- menu categories -->
    <menuitem name="Gestores" id="gestores.menu_gestores" parent="gestores.menu_root" groups="base.group_system"/>

    <!-- actions -->
    <menuitem name="Todos los Gestores" id="gestores.menu_1_list" parent="gestores.menu_gestores"
              action="gestores.action_window" groups="base.group_system"/>
  </data>
</odoo>
