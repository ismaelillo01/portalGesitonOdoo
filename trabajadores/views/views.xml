<odoo>
  <data>
    <!-- explicit list view definition -->
    <record model="ir.ui.view" id="trabajadores.trabajador_list">
      <field name="name">trabajador.list</field>
      <field name="model">trabajadores.trabajador</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="apellido1"/>
          <field name="dni_nie"/>
          <field name="telefono"/>
          <field name="grupo"/>
          <field name="zona_trabajo_ids" widget="many2many_tags"/>
          <field name="baja"/>
        </list>
      </field>
    </record>

    <!-- explicit form view definition -->
    <record model="ir.ui.view" id="trabajadores.trabajador_form">
      <field name="name">trabajador.form</field>
      <field name="model">trabajadores.trabajador</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group string="Datos Personales">
                <field name="name"/>
                <field name="apellido1"/>
                <field name="apellido2"/>
                <field name="dni_nie"/>
              </group>
              <group string="Datos de Contacto">
                <field name="telefono"/>
                <field name="direccion"/>
              </group>
            </group>
            <group string="Datos Laborales">
              <group>
                <field name="grupo"/>
                <field name="zona_trabajo_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}"/>
              </group>
              <group>
                <field name="baja"/>
              </group>
            </group>
            <!-- Añado nueva pestaña para las vacaciones si no está de baja -->
            <notebook invisible="baja == True">
              <page string="Vacaciones">
                <field name="vacaciones_ids">
                  <list editable="bottom">
                    <field name="name"/>
                    <field name="date_start"/>
                    <field name="date_stop"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="trabajadores.action_window">
      <field name="name">Trabajadores</field>
      <field name="res_model">trabajadores.trabajador</field>
      <field name="view_mode">list,form</field>
    </record>

    <!-- views for vacacion -->
    <record model="ir.ui.view" id="trabajadores.vacacion_calendar">
        <field name="name">vacacion.calendar</field>
        <field name="model">trabajadores.vacacion</field>
        <field name="arch" type="xml">
            <calendar string="Vacaciones" date_start="date_start" date_stop="date_stop" color="trabajador_id" mode="month" quick_create="False">
                <field name="trabajador_id"/>
            </calendar>
        </field>
    </record>

    <record model="ir.ui.view" id="trabajadores.vacacion_search">
        <field name="name">vacacion.search</field>
        <field name="model">trabajadores.vacacion</field>
        <field name="arch" type="xml">
            <search string="Buscar Vacaciones">
                <field name="trabajador_id" string="Trabajador" domain="[('baja', '=', False)]"/>
                <searchpanel>
                    <field name="trabajador_id" icon="fa-users" enable_counters="1" select="multi"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record model="ir.ui.view" id="trabajadores.vacacion_form">
        <field name="name">vacacion.form</field>
        <field name="model">trabajadores.vacacion</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="trabajador_id"/>
                        <field name="name"/>
                        <field name="date_start"/>
                        <field name="date_stop"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="trabajadores.action_vacacion_window">
      <field name="name">Calendario de Vacaciones</field>
      <field name="res_model">trabajadores.vacacion</field>
      <field name="view_mode">calendar,list,form</field>
    </record>

    <!-- Top menu item -->
    <menuitem name="Trabajadores" id="trabajadores.menu_root"/>

    <!-- menu categories -->
    <menuitem name="Trabajadores" id="trabajadores.menu_trabajadores" parent="trabajadores.menu_root"/>

    <!-- actions -->
    <menuitem name="Todos los Trabajadores" id="trabajadores.menu_1_list" parent="trabajadores.menu_trabajadores"
              action="trabajadores.action_window" sequence="10"/>
    <menuitem name="Calendario Vacaciones" id="trabajadores.menu_vacaciones_cal" parent="trabajadores.menu_trabajadores"
              action="trabajadores.action_vacacion_window" sequence="20"/>
  </data>
</odoo>
