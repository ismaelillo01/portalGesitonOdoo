<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_portal_ap_fichaje_report_wizard_form" model="ir.ui.view">
        <field name="name">portal.ap.fichaje.report.wizard.form</field>
        <field name="model">portal.ap.fichaje.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte Excel de Fichajes AP">
                <sheet>
                    <group>
                        <field
                            name="trabajador_id"
                            options="{'no_create': True, 'no_open': True}"
                            domain="[('baja', '=', False)]"
                        />
                        <field name="mes"/>
                        <field name="anio"/>
                        <field name="fecha_inicio" invisible="1"/>
                        <field name="fecha_fin" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Descargar Excel" type="object" name="action_download_excel" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_portal_ap_fichaje_report_wizard" model="ir.actions.act_window">
        <field name="name">Reporte Excel de Fichajes AP</field>
        <field name="res_model">portal.ap.fichaje.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_portal_ap_fichaje_report_wizard_form"/>
        <field name="target">new</field>
        <field name="groups_id" eval="[(6, 0, [ref('gestores.group_gestores_agusto'), ref('gestores.group_gestores_intecum'), ref('gestores.group_gestores_administrador')])]"/>
    </record>
</odoo>
