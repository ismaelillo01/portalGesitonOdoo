<odoo>
  <data>
    <record model="ir.ui.view" id="zona_list">
      <field name="name">zonastrabajo.zona.list</field>
      <field name="model">zonastrabajo.zona</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence"/>
          <field name="name"/>
          <field name="code"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="zona_form">
      <field name="name">zonastrabajo.zona.form</field>
      <field name="model">zonastrabajo.zona</field>
      <field name="arch" type="xml">
        <form string="Zona de Trabajo">
          <sheet>
            <group>
              <field name="name"/>
              <field name="code"/>
              <field name="sequence"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="action_window">
      <field name="name">Zonas de Trabajo</field>
      <field name="res_model">zonastrabajo.zona</field>
      <field name="view_mode">list,form</field>
      <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <record model="ir.ui.view" id="localidad_list">
      <field name="name">zonastrabajo.localidad.list</field>
      <field name="model">zonastrabajo.localidad</field>
      <field name="arch" type="xml">
        <list editable="bottom">
          <field name="name"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="localidad_search">
      <field name="name">zonastrabajo.localidad.search</field>
      <field name="model">zonastrabajo.localidad</field>
      <field name="arch" type="xml">
        <search string="Buscar Localidad">
          <field name="name"/>
          <filter name="inactive" string="Archivadas" domain="[('active', '=', False)]"/>
        </search>
      </field>
    </record>

    <record model="ir.ui.view" id="localidad_form">
      <field name="name">zonastrabajo.localidad.form</field>
      <field name="model">zonastrabajo.localidad</field>
      <field name="arch" type="xml">
        <form string="Localidad">
          <sheet>
            <group>
              <field name="name"/>
              <field name="active"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="action_localidad_window">
      <field name="name">Localidades</field>
      <field name="res_model">zonastrabajo.localidad</field>
      <field name="view_mode">list,form</field>
      <field name="search_view_id" ref="localidad_search"/>
      <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>
  </data>
</odoo>
